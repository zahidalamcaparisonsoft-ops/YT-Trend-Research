# ---- Supabase (Project Settings -> API) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- YouTube Data API v3 (Google Cloud Console -> APIs & Services -> Credentials -> API key) ----
YOUTUBE_API_KEY=

# ---- OpenAI (for script + asset generation) ----
OPENAI_API_KEY=
# Set this to your preferred best model, e.g. gpt-4o / gpt-4.1 / gpt-5 (whatever your account has)
OPENAI_MODEL=gpt-4o
